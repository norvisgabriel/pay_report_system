generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String?
  password      String?
  role          Role      @default(USER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  payments         Payment[]
  paymentsCreated  Payment[] @relation("CreatedBy")
  sessions         Session[]
  accounts         Account[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments      Payment[]
  exchangeRates ExchangeRate[]

  @@map("campaigns")
}

model ExchangeRate {
  id            String   @id @default(cuid())
  campaignId    String?
  fromCurrency  String   @default("USD")
  toCurrency    String   @default("VES")
  rate          Decimal  @db.Decimal(12, 4)
  effectiveDate DateTime @db.Date
  source        String   @default("dolarapi")
  createdAt     DateTime @default(now())

  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@unique([fromCurrency, toCurrency, effectiveDate])
  @@map("exchange_rates")
}

model Payment {
  id            String        @id @default(cuid())
  userId        String
  campaignId    String
  createdById   String?       // admin who created manual payment

  // Montos — siempre USD → VES
  amount        Decimal       @db.Decimal(12, 2)   // en USD
  exchangeRate  Decimal?      @db.Decimal(12, 4)   // tasa VES/USD usada
  localAmount   Decimal?      @db.Decimal(12, 2)   // en VES

  // Método de pago
  method        String        // efectivo | transferencia | pago_movil

  // Campos según método (todos opcionales a nivel DB)
  bankName      String?       // transferencia + pago_movil
  reference     String?       // transferencia
  phoneNumber   String?       // pago_movil

  paymentDate   DateTime      @db.Date
  imageUrl      String?       // comprobante (requerido salvo efectivo manual)
  imagePublicId String?

  status        PaymentStatus @default(PENDING)
  notes         String?       @db.Text
  adminNotes    String?       @db.Text
  isManual      Boolean       @default(false)
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user       User      @relation(fields: [userId], references: [id])
  createdBy  User?     @relation("CreatedBy", fields: [createdById], references: [id])
  campaign   Campaign  @relation(fields: [campaignId], references: [id])
  receipt    Receipt?

  @@map("payments")
}

model Receipt {
  id         String   @id @default(cuid())
  paymentId  String   @unique
  token      String   @unique @default(cuid())
  validUntil DateTime? // 6 meses desde la aprobación (null = sin expiración)
  createdAt  DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("receipts")
}

enum Role {
  USER
  ADMIN
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}
